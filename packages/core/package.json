{
  "name": "tabcoord",
  "version": "0.1.3",
  "description": "Multi-tab coordination layer — shared state, leader election, distributed locks, event bus",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./diff": {
      "types": "./dist/diff-standalone.d.ts",
      "import": "./dist/diff-standalone.js",
      "default": "./dist/diff-standalone.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ihssmaheel-dev/tabcoord.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ihssmaheel-dev/tabcoord#readme",
  "bugs": {
    "url": "https://github.com/ihssmaheel-dev/tabcoord/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "echo ok",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.0",
    "size-limit": "^11.0.0",
    "vitest": "^3.0.0"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "5 KB"
    }
  ],
  "engines": {
    "node": ">=18"
  }
}
